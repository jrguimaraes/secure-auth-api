generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  userAgent String
  ip        String
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id           String    @id @default(uuid())
  sessionId    String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())

  session      Session   @relation(fields: [sessionId], references: [id])
}
